// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  username    String?  @unique
  email       String   @unique
  password    String
  profilePhoto String?  @map("profile_photo") // Optional profile photo URL/path
  bio         String?  // User bio/tagline
  location    String?  // User location
  github      String?  // GitHub username
  twitter     String?  // Twitter username
  linkedin    String?  // LinkedIn username
  website     String?  // Personal website
  isOnline    Boolean  @default(false) @map("is_online") // Online status
  lastActive  DateTime? @map("last_active") // Last active timestamp
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @updatedAt @map("updated_at")

  // Relations
  userIdChanges UserIdChange[]

  @@map("users")
}

model UserIdChange {
  id        String   @id @default(cuid())
  userId    String   // References the current user ID
  oldId     String   // The previous user ID
  newId     String   // The new user ID
  changedAt DateTime @default(now()) @map("changed_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("user_id_changes")
}
